{
  "name": "nestjs-nextjs-mvc-starter",
  "private": true,
  "version": "1.0.0",
  "description": "Nest TypeScript starter repository",
  "license": "MIT",
  "scripts": {
    "nest": "nest",
    "next": "cd src/client && next",
    "prebuild": "rimraf dist",
    "build": "NODE_ENV=production nest build && cd src/client && next build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch --preserveWatchOutput",
    "start:debug": "nest start --debug --watch --preserveWatchOutput",
    "start:prod": "NODE_ENV=production node dist/src/server/main",
    "lint": "eslint \"{src,test}/**/*.{ts,tsx}\"",
    "test": "jest --setupFiles dotenv-flow/config --collect-coverage",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:request": "jest --setupFiles dotenv-flow/config --config ./test/jest-request.json",
    "console": "ts-node -r tsconfig-paths/register src/server/console.ts",
    "typeorm": "typeorm-ts-node-commonjs -d ormconfig.ts",
    "client:generate:schema": "zeus src/schema.gql src/client/app/types --typescript --apollo",
    "cy": "cypress",
    "scaffold": "cd node_modules/@web/scaffold & cross-env NODE_ENV=production nest start"
  },
  "dependencies": {
    "@apollo/client": "^3.7.17",
    "@apollo/gateway": "^2.4.12",
    "@babel/runtime": "^7.20.7",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mui/icons-material": "5.15.16",
    "@mui/lab": "^5.0.0-alpha.170",
    "@mui/material": "^5.15.16",
    "@mui/x-date-pickers": "^7.3.2",
    "@nestjs/apollo": "12.1.0",
    "@nestjs/common": "^10.3.8",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.3.8",
    "@nestjs/graphql": "12.1.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.8",
    "@nestjs/typeorm": "^10.0.0",
    "apollo-server-express": "^3.11.1",
    "axios": "^1.2.2",
    "commander": "^11.0.0",
    "cookie-parser": "^1.4.6",
    "dayjs": "^1.11.11",
    "easy-peasy": "^5.0.4",
    "formik": "^2.2.9",
    "google-auth-library": "^8.7.0",
    "graphql": "^16.7.1",
    "nestjs-console": "9.0.0",
    "next": "14.2.3",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "passport-oauth2": "^1.6.1",
    "react": "^18.1.0",
    "react-content-loader": "7.0.0",
    "react-dom": "^18.1.0",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^3.0.2",
    "rxjs": "^7.8.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "ts-morph": "^17.0.1",
    "typeorm": "^0.3.11"
  },
  "devDependencies": {
    "@babel/parser": "^7.24.1",
    "@babel/types": "^7.24.0",
    "@faker-js/faker": "^7.6.0",
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.8",
    "@next/eslint-plugin-next": "^13.1.1",
    "@types/body-parser": "^1.19.5",
    "@types/cookie-parser": "^1.4.3",
    "@types/eslint": "^8.56.6",
    "@types/express": "^4.17.17",
    "@types/gtag.js": "^0.0.12",
    "@types/jest": "^28.1.8",
    "@types/next": "^9.0.0",
    "@types/node": "^18.11.18",
    "@types/passport-google-oauth20": "^2.0.11",
    "@types/passport-jwt": "^3.0.8",
    "@types/passport-local": "^1.0.34",
    "@types/passport-oauth2": "^1.4.11",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^5.47.1",
    "@typescript-eslint/parser": "^5.47.1",
    "connect": "^3.7.0",
    "cookiejar": "^2.1.4",
    "cypress": "^12.2.0",
    "dotenv-flow": "^3.2.0",
    "eslint": "^8.31.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "fishery": "^2.2.2",
    "graphql-zeus": "^5.3.2",
    "istanbul-lib-coverage": "^3.2.2",
    "jest": "^28.1.3",
    "json-schema": "^0.4.0",
    "mime": "^4.0.1",
    "prettier": "^3.3.3",
    "supertest": "^6.3.3",
    "ts-jest": "^28.0.8",
    "ts-loader": "^9.4.2",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.1.1",
    "typescript": "^4.9.4"
  }
}
